# ═══════════════════════════════════════
# Prospector Chevla — Environment Config
# Copy to .env and fill in real values
# ═══════════════════════════════════════

# Server
PORT=3001

# JWT (REQUIRED in production — generates random if not set)
JWT_SECRET=your-strong-secret-here-min-32-chars

# Admin credentials
ADMIN_USERNAME=AdminChevla
ADMIN_PASSWORD=change-this-password

# Email (SMTP/IMAP)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
IMAP_HOST=imap.hostinger.com
IMAP_PORT=993
EMAIL_ADDRESS=Contato@Chevla.com
EMAIL_PASSWORD=your-email-password

# CORS - comma-separated production origins
ALLOWED_ORIGINS=https://your-crm-domain.com

# Google Maps API (for prospecting)
GOOGLE_MAPS_API_KEY=

# Google PageSpeed API
PAGESPEED_API_KEY=
